rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Questions and question sets are public read (no auth needed for learners)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false; // Admin panel uses service account
    }

    match /question_sets/{setId} {
      allow read: if true;
      allow write: if false;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }

    match /study_materials/{materialId} {
      allow read: if true;
      allow write: if false;
    }

    match /video_guides/{guideId} {
      allow read: if true;
      allow write: if false;
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if false;
    }

    // Attempts and user progress require authentication
    match /attempts/{attemptId} {
      allow read, write: if request.auth != null 
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Admin-only collections (no client access)
    match /admin/{document=**} {
      allow read, write: if false;
    }

    // Ask the Expert feature collections
    match /ai_cache/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /system_prompts/{docId} {
      allow read, write: if request.auth != null;
    }
    match /ai_model_pricing/{docId} {
      allow read, write: if request.auth != null;
    }
    match /feature_flags/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /admin_api_keys/{docId} {
      allow read, write: if request.auth != null;
    }
    match /admin_api_key_audit_log/{docId} {
      allow read, write: if request.auth != null;
    }
    match /ask_expert_questions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /ask_expert_feedback/{docId} {
      allow read, write: if request.auth != null;
    }
    match /ad_reward_logs/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
