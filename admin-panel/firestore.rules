rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isAdminOrSuperAdmin() {
      return isAdmin() || isSuperAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if isAdminOrSuperAdmin();
    }

    match /questions/{questionId} {
      allow read:                    if isSignedIn();
      allow create, update, delete:  if isAdminOrSuperAdmin();
    }

    match /study_materials/{materialId} {
      allow read:                    if isSignedIn();
      allow create, update, delete:  if isAdminOrSuperAdmin();
    }

    match /app_users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdminOrSuperAdmin();
    }

    match /exam_results/{resultId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read:   if isAdminOrSuperAdmin();
    }

    match /notices/{noticeId} {
      allow read:                    if isSignedIn() && resource.data.status == 'Published';
      allow read, create, update, delete: if isAdminOrSuperAdmin();
    }

    match /app_settings/{settingId} {
      allow read:                    if isSignedIn();
      allow create, update, delete:  if isAdminOrSuperAdmin();
    }

    match /question_sets/{setId} {
      allow read:                    if isSignedIn();
      allow create, update, delete:  if isAdminOrSuperAdmin();
    }
  }
}
